---
import AppLayout from "@layouts/AppLayout.astro";
import Hero from "@components/Hero.astro";
import AboutSection from "@components/AboutSection.astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import ProjectShowcase from "@components/ProjectShowcase.astro";
import SectionHeading from "@components/SectionHeading.astro";
import CertificationCard from "@components/CertificationCard.astro";
import BlogCard from "@components/BlogCard.astro";
import ContactSection from "@components/ContactSection.astro";
import { certifications } from "@data/certifications";
import { getLangFromUrl, useTranslations } from "../../i18n/home/utils";
import { useTranslations as useCertTranslations } from "../../i18n/certifications/ui";
import { getCollection } from "astro:content";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tCert = useCertTranslations(lang as "en" | "es");

const posts = (await getCollection("blog"))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .filter((a) => a.data.language === lang)
  .slice(0, 3);
---

<AppLayout title={t("home.pageTitle")}>
  <Hero lang={lang} />
  <AboutSection lang={lang} />
  <ExperienceTimeline lang={lang} />
  <ProjectShowcase lang={lang} />

  <!-- Certifications -->
  <section id="certifications" class="py-20 sm:py-28">
    <SectionHeading title={t("home.certificationsTitle")} number="04" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        certifications.map((cert) => (
          <CertificationCard
            name={tCert(cert.nameKey)}
            issuer={tCert(cert.issuerKey)}
            date={tCert(cert.dateKey)}
            description={tCert(cert.descriptionKey)}
          />
        ))
      }
    </div>
  </section>

  <!-- Latest Posts -->
  <section id="blog" class="py-20 sm:py-28">
    <SectionHeading title={t("home.latestPosts")} number="05" />
    <ul class="space-y-4">
      {
        posts.map((post) => (
          <BlogCard
            title={post.data.title}
            pubDate={post.data.pubDate}
            description={post.data.description}
            url={`/blog/${post.slug}/`}
            tags={post.data.tags}
          />
        ))
      }
    </ul>
    {
      posts.length > 0 && (
        <div class="text-center mt-8" data-animate>
          <a
            href={`/${lang}/blog/`}
            class="text-accent hover:text-accent-light transition-colors text-sm font-medium"
          >
            {t("home.viewAllPosts")} &rarr;
          </a>
        </div>
      )
    }
  </section>

  <ContactSection lang={lang} />
</AppLayout>
