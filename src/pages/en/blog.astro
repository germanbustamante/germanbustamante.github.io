---
import AppLayout from "@layouts/AppLayout.astro";
import BlogCard from "@components/BlogCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/home/utils";
import { getCollection } from "astro:content";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection("blog"))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .filter((a) => a.data.language === lang);

const title = `Blog — ${t("home.pageTitle")}`;
const description = t("home.pageDescription");
---

<AppLayout title={title} description={description}>
  <div class="pt-24 pb-16">
    <SectionHeading title="Blog" />
    <ul class="space-y-4">
      {
        posts.map((post) => (
          <BlogCard
            title={post.data.title}
            pubDate={post.data.pubDate}
            description={post.data.description}
            url={`/blog/${post.slug}/`}
            tags={post.data.tags}
          />
        ))
      }
    </ul>
    {
      posts.length === 0 && (
        <p class="text-center text-zinc-500 dark:text-zinc-500 py-12">
          No posts yet. Check back soon!
        </p>
      )
    }
  </div>
</AppLayout>
