---
import AppLayout from "@layouts/AppLayout.astro";
const title = "Página No Encontrada";
const description = "Lo sentimos, la página que buscas no existe.";
---

<AppLayout title={title} description={description}>
  <div
    class="flex flex-col items-center justify-center min-h-[60vh] text-center pt-24"
  >
    <p class="text-accent font-mono text-lg mb-2">404</p>
    <h1 class="font-bold text-3xl sm:text-4xl mb-4 text-zinc-900 dark:text-zinc-100">
      Página No Encontrada
    </h1>
    <p class="text-zinc-500 dark:text-zinc-400 mb-8 max-w-md">
      {description}
    </p>
    <a
      class="px-6 py-3 rounded-lg bg-accent text-white font-medium hover:bg-accent-dark transition-colors"
      href="/es/"
    >
      Volver al inicio
    </a>
  </div>
</AppLayout>
