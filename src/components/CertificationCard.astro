---
interface Props {
  name: string;
  issuer: string;
  date: string;
  description: string;
}

const { name, issuer, date, description } = Astro.props;
---

<div
  class="p-5 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-surface-card hover:border-accent/30 dark:hover:border-accent/30 transition-colors"
  data-animate
>
  <div class="flex items-start gap-4">
    <div
      class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center"
    >
      <svg
        class="w-5 h-5 text-accent"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
        ></path>
      </svg>
    </div>
    <div>
      <h3 class="font-bold text-zinc-900 dark:text-zinc-100">{name}</h3>
      <p class="text-sm text-accent font-medium">{issuer}</p>
      <p class="text-xs text-zinc-500 dark:text-zinc-500 mt-1">{date}</p>
      <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-2">
        {description}
      </p>
    </div>
  </div>
</div>
