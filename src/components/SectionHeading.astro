---
interface Props {
  title: string;
  number?: string;
}

const { title, number } = Astro.props;
---

<div class="flex items-center gap-4 mb-10" data-animate>
  {
    number && (
      <span class="text-accent font-mono text-sm">{number}.</span>
    )
  }
  <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100">
    {title}
  </h2>
  <div class="flex-1 h-px bg-zinc-200 dark:bg-zinc-800"></div>
</div>
