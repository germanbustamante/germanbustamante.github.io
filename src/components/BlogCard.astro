---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  url: string;
  tags: string[];
}

const { title, description, pubDate, url, tags } = Astro.props;

const fullDate = pubDate.toLocaleDateString("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<li
  class="group p-6 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-surface-card hover:border-accent/30 dark:hover:border-accent/30 transition-all duration-300"
  data-animate
>
  <a class="flex flex-col gap-3" href={url}>
    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
      <h3
        class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-accent transition-colors [word-break:break-word]"
      >
        {title}
      </h3>
      <time
        datetime={pubDate.toISOString()}
        class="text-sm text-zinc-500 dark:text-zinc-500 whitespace-nowrap"
      >
        {fullDate}
      </time>
    </div>
    <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5 mt-1">
      {
        tags.map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400">
            {tag}
          </span>
        ))
      }
    </div>
  </a>
</li>
