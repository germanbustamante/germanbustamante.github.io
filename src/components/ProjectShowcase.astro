---
import SectionHeading from "@components/SectionHeading.astro";
import { projects } from "@data/projects";
import { useTranslations } from "../i18n/home/utils";
import { useTranslations as useProjTranslations } from "../i18n/project/ui";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as "en" | "es");
const tProj = useProjTranslations(lang as "en" | "es");
---

<section id="projects" class="py-20 sm:py-28">
  <SectionHeading title={t("home.projectsTitle")} number="03" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {
      projects
        .filter((p) => p.featured)
        .map((project) => (
          <div
            class="group rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-surface-card overflow-hidden hover:border-accent/30 dark:hover:border-accent/30 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5"
            data-animate
          >
            {/* Gradient placeholder image */}
            <div class="relative h-48 bg-gradient-to-br from-accent/20 via-accent/5 to-transparent flex items-center justify-center">
              <span class="text-2xl font-bold text-accent/40">
                {tProj(project.nameKey)}
              </span>
              {/* Status badge */}
              <div class="absolute top-3 right-3">
                <span
                  class:list={[
                    "text-xs font-medium px-2.5 py-1 rounded-full",
                    project.status === "coming-soon" &&
                      "bg-zinc-100 dark:bg-zinc-800 text-zinc-500",
                    project.status === "in-development" &&
                      "bg-accent/10 text-accent",
                    project.status === "live" && "bg-green-100 text-green-700",
                  ]}
                >
                  {project.status === "coming-soon" && t("home.comingSoon")}
                  {project.status === "in-development" &&
                    t("home.inDevelopment")}
                  {project.status === "live" && "Live"}
                </span>
              </div>
            </div>

            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-100">
                  {tProj(project.nameKey)}
                </h3>
                <div class="flex gap-2">
                  {project.githubUrl && (
                    <a
                      href={project.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-zinc-400 hover:text-accent transition-colors"
                      aria-label="GitHub repository"
                    >
                      <svg
                        class="w-5 h-5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                      >
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                      </svg>
                    </a>
                  )}
                  {project.liveUrl && (
                    <a
                      href={project.liveUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-zinc-400 hover:text-accent transition-colors"
                      aria-label="Live demo"
                    >
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </div>

              <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4 leading-relaxed">
                {tProj(project.descriptionKey)}
              </p>

              {/* Architecture highlights */}
              <ul class="space-y-1 mb-4">
                {project.highlightsKeys.map((key) => (
                  <li class="text-xs text-zinc-500 dark:text-zinc-500 flex items-center gap-2">
                    <span class="text-accent">&#9656;</span>
                    {tProj(key)}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {project.technologies.map((tech) => (
                  <span class="text-xs px-2 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
    }
  </div>
</section>
