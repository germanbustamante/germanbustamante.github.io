---
import SectionHeading from "@components/SectionHeading.astro";
import { experience } from "@data/experience";
import { useTranslations } from "../i18n/home/utils";
import { useTranslations as useExpTranslations } from "../i18n/experience/ui";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as "en" | "es");
const tExp = useExpTranslations(lang as "en" | "es");
---

<section id="experience" class="py-20 sm:py-28">
  <SectionHeading title={t("home.experienceTitle")} number="02" />

  <div class="relative">
    <!-- Timeline line -->
    <div
      class="absolute left-0 md:left-8 top-0 bottom-0 w-px bg-zinc-200 dark:bg-zinc-800"
      aria-hidden="true"
    >
    </div>

    <div class="space-y-12">
      {
        experience.map((entry) => (
          <div class="relative pl-8 md:pl-20" data-animate>
            {/* Timeline dot */}
            <div class="absolute left-0 md:left-8 top-1 w-px h-px">
              <div class="absolute -left-[5px] -top-[5px] w-3 h-3 rounded-full bg-accent border-2 border-white dark:border-[#0a0a0a]" />
            </div>

            {/* Card */}
            <div class="p-6 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-surface-card hover:border-accent/30 dark:hover:border-accent/30 transition-colors">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
                <div>
                  <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100">
                    {entry.company}
                  </h3>
                  <p class="text-accent font-medium">
                    {tExp(entry.roleKey)}
                  </p>
                </div>
                <div class="text-sm text-zinc-500 dark:text-zinc-500 text-right">
                  <p>{tExp(entry.periodKey)}</p>
                  <p class="flex items-center gap-1 justify-end">
                    {tExp(entry.locationKey)}
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-accent/10 text-accent">
                      {tExp(entry.typeKey)}
                    </span>
                  </p>
                </div>
              </div>

              <ul class="space-y-3 mb-4">
                {entry.bulletKeys.map((bulletKey) => (
                  <li class="flex gap-3 text-sm text-zinc-600 dark:text-zinc-400">
                    <span class="text-accent mt-1 flex-shrink-0">&#9656;</span>
                    <span>{tExp(bulletKey)}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {entry.technologies.map((tech) => (
                  <span class="text-xs px-2 py-1 rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
