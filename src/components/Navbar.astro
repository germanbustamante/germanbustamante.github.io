---
import navigation from "@data/navigation.json";
import { useTranslations } from "../i18n/navigation/ui";
import { githubUrl, linkedinUrl, email } from "@data/socials";
import ThemeToggle from "@components/ThemeToggle.astro";
import LanguageSwitcher from "@components/LanguageSwitcher.astro";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as "en" | "es");
const isIndex = Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-200/10 dark:border-zinc-800/50 bg-white/80 dark:bg-[#0a0a0a]/80 backdrop-blur-lg"
  id="navbar"
>
  <div class="max-w-5xl mx-auto px-6 flex items-center justify-between h-16">
    <!-- Logo / Name -->
    <a
      href={`/${lang}/`}
      class="text-lg font-bold text-zinc-900 dark:text-zinc-100 hover:text-accent dark:hover:text-accent transition-colors"
    >
      GB
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-6 text-sm">
      {
        navigation.map((item) => {
          const href =
            item.type === "page" ? `/${lang}${item.href}` : isIndex ? item.href : `/${lang}/${item.href}`;
          return (
            <li>
              <a
                href={href}
                class="text-zinc-600 dark:text-zinc-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                {t(item.text)}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- Right side: Language, Theme, Socials -->
    <div class="flex items-center gap-3">
      <LanguageSwitcher lang={lang} />
      <ThemeToggle />

      <div class="hidden sm:flex items-center gap-2 ml-2 border-l border-zinc-300 dark:border-zinc-700 pl-3">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-500 hover:text-accent transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-500 hover:text-accent transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <a
          href={`mailto:${email}`}
          class="text-zinc-500 hover:text-accent transition-colors"
          aria-label="Email"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        class="md:hidden text-zinc-600 dark:text-zinc-400 hover:text-accent"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="hidden md:hidden border-t border-zinc-200/10 dark:border-zinc-800/50" id="mobile-menu">
    <ul class="px-6 py-4 space-y-3">
      {
        navigation.map((item) => {
          const href =
            item.type === "page" ? `/${lang}${item.href}` : isIndex ? item.href : `/${lang}/${item.href}`;
          return (
            <li>
              <a
                href={href}
                class="block text-zinc-600 dark:text-zinc-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                {t(item.text)}
              </a>
            </li>
          );
        })
      }
      <li class="flex gap-4 pt-2 border-t border-zinc-200/10 dark:border-zinc-800/50">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-500 hover:text-accent transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-500 hover:text-accent transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <a
          href={`mailto:${email}`}
          class="text-zinc-500 hover:text-accent transition-colors"
          aria-label="Email"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </a>
      </li>
    </ul>
  </div>
</nav>

<script is:inline>
  (function () {
    var btn = document.getElementById("mobile-menu-btn");
    var menu = document.getElementById("mobile-menu");
    if (btn && menu) {
      btn.addEventListener("click", function () {
        menu.classList.toggle("hidden");
      });
      // Close menu when clicking a link
      menu.querySelectorAll("a").forEach(function (link) {
        link.addEventListener("click", function () {
          menu.classList.add("hidden");
        });
      });
    }
  })();
</script>
