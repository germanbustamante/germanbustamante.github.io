---
import AppLayout from "@layouts/AppLayout.astro";
import Pagination from "@components/Pagination.astro";
import { Image } from "astro:assets";
import authorImage from "../assets/me.png";
import type { ImageMetadata } from "astro";
import { author, tag, githubUrl } from "@data/socials";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  pubDate: Date;
  url: string;
  updatedDate: Date | undefined;
  tags: string[];
  language: string;
}

const { title, description, image, imageAlt, pubDate, url, updatedDate, tags } =
  Astro.props;

const ogImage = {
  src: `/image/${url}.png`,
  alt: title,
};

const fullPubDate = pubDate.toLocaleDateString("en", {
  dateStyle: "full",
});

// updatedDate is available via props if needed in the future
---

<AppLayout
  title={title}
  description={description}
  ogImage={ogImage}
  pubDate={updatedDate ?? pubDate}
  tags={tags}
>
  <header class="flex flex-col mb-8 pt-24">
    <h1
      class="text-2xl sm:text-4xl pb-8 font-bold text-center text-transparent bg-clip-text bg-gradient-to-r from-accent-dark to-accent-light"
    >
      {title}
    </h1>
    <div
      class="inline-flex items-center mb-8 justify-between align-middle flex-wrap gap-2"
    >
      <time
        datetime={pubDate.toISOString()}
        class="block text-center dark:text-zinc-400 text-zinc-600 mb-4 text-sm sm:text-base"
      >
        {fullPubDate}
      </time>
      <div class="flex items-center gap-4">
        <div class="aspect-square rounded-full overflow-hidden">
          <Image
            src={authorImage}
            alt="Image of the author"
            loading="eager"
            class="aspect-square w-10"
            width={80}
            height={80}
          />
        </div>
        <p class="dark:text-zinc-400 text-zinc-700 text-sm">
          <span class="block font-semibold">{author}</span>
          <a
            class="text-accent hover:text-accent-light hover:underline block"
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {tag}
          </a>
        </p>
      </div>
    </div>
    <Image
      src={image}
      alt={imageAlt}
      loading="eager"
      class="rounded-lg"
      width={1200}
      height={630}
    />
  </header>
  <article
    class="prose dark:prose-invert lg:prose-lg dark:prose-code:text-zinc-300 dark:prose-a:text-accent prose-a:text-accent-dark max-w-none hover:prose-a:underline focus:prose-a:underline prose-a:no-underline dark:prose-headings:text-accent prose-img:rounded-lg"
  >
    <slot />
  </article>
  <Pagination />
</AppLayout>
