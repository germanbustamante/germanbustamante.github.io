---
import { author, defaultMeta, githubUrl, linkedinUrl } from "@data/socials";
import "@fontsource-variable/inter";
import "@styles/global.css";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import { getLangFromUrl } from "../i18n/home/utils";

interface Props {
  title?: string;
  description?: string;
  ogImage?: {
    src: string;
    alt: string;
  };
  pubDate?: Date;
  tags?: string[];
  lastmod?: Date;
}

const {
  title,
  description = defaultMeta.description,
  ogImage = defaultMeta.ogImage,
  pubDate,
  tags = defaultMeta.keywords,
  lastmod,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const ogImageURL = new URL(ogImage.src, Astro.site).href;
const canonicalURL = new URL(Astro.url).href;
const date = pubDate || lastmod || new Date();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Germán De Bustamante Conde",
  jobTitle: "Senior Android Architect",
  url: "https://germanbustamante.github.io",
  sameAs: [githubUrl, linkedinUrl],
  knowsAbout: [
    "Kotlin",
    "Android",
    "Kotlin Multiplatform",
    "Jetpack Compose",
    "Clean Architecture",
  ],
};
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title || defaultMeta.title}</title>
    <link rel="canonical" href={canonicalURL} />
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={author} />
    <meta property="og:image:alt" content={ogImage.alt} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="https://germanbustamante.github.io" />
    <meta name="twitter:creator" content={author} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImage.alt} />
    <meta name="twitter:domain" content="germanbustamante.github.io" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="msapplication-TileColor" content="#0a0a0a" />
    <meta name="color-scheme" content="dark light" />
    <meta name="apple-mobile-web-app-title" content={title} />
    <meta name="application-name" content={title} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="follow, index" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-icon-180x180.png"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/manifest.json" />
    {
      tags &&
        tags.map((tag) => <meta property="article:tag" content={tag} />)
    }
    <meta name="author" content={author} />
    <meta name="date" content={date} />
    <meta name="keywords" content={tags} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Dark mode: prevent FOUC -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        if (theme === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-white dark:bg-[#0a0a0a] text-zinc-900 dark:text-zinc-100 antialiased selection:bg-accent/30 selection:text-accent-dark dark:selection:bg-accent/30 dark:selection:text-accent-light 2xl:text-lg"
  >
    <Navbar lang={lang} />

    <main class="px-6 lg:px-0 mx-auto max-w-5xl min-h-screen" id="main-content">
      <slot />
    </main>

    <Footer lang={lang} />

    <!-- Intersection Observer for scroll animations -->
    <script is:inline>
      (function () {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("animate-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 },
        );

        document
          .querySelectorAll("[data-animate], [data-animate-stagger]")
          .forEach(function (el) {
            observer.observe(el);
          });
      })();
    </script>

    <!-- Google Analytics -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-1GQ8HDJ8L1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-1GQ8HDJ8L1");
    </script>
  </body>
</html>
